<!DOCTYPE html>
<html>

<head>
    <title>Counter App</title>
    <style>
        body {
            font-family: Arial;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            background: #f0f0f0;
        }

        .card {
            background: #fff;
            padding: 30px;
            border-radius: 10px;
            text-align: center;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.2);
        }

        h2 {
            margin-bottom: 10px;
        }

        #count {
            font-size: 40px;
            margin: 20px 0;
        }

        button {
            padding: 10px 15px;
            margin: 5px;
            border: none;
            background: #007bff;
            color: white;
            border-radius: 5px;
            cursor: pointer;
        }

        button:hover {
            background: #0056b3;
        }
    </style>
</head>

<body>

    <div class="card">
        <h2>React Counter Application</h2>
        <div id="count">0</div>

        <button onclick="increment()">Increment (+)</button>
        <button onclick="decrement()">Decrement (-)</button>
        <br><br>
        <button onclick="reset()">Reset</button>
    </div>

    <script>
        let count = 0;

        function updateDisplay() {
            document.getElementById("count").innerText = count;
        }

        function increment() {
            count++;
            updateDisplay();
        }

        function decrement() {
            count--;
            updateDisplay();
        }

        function reset() {
            count = 0;
            updateDisplay();
        }
    </script>

</body>

</html>